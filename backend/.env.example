# Database Configuration (MongoDB Atlas URL)
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/siksha_kendra?retryWrites=true&w=majority"

# Application Config
PORT=5000
NODE_ENV=production

# Frontend URL for CORS configuration
FRONTEND_URL=https://your-frontend-project.vercel.app

# Super Admin Credentials
SUPER_ADMIN_EMAIL="admin@topperssikshakendra.com"
SUPER_ADMIN_PASSWORD="YourSecurePassword123!"

# Authentication Secrets
JWT_SECRET="your-super-secret-jwt-key"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email / Nodemailer (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@topperssikshakendra.com"

# Cloudinary Setup
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
